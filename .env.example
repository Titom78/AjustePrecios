# API server
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=

# SQL Server connection
DB_USER=your_user
DB_PASSWORD=your_password
DB_SERVER=your_sql_host
DB_NAME=your_database
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_CONNECT_TIMEOUT=30000

# Frontend (optional)
# Leave empty when frontend and API share same domain and reverse proxy /api.
VITE_API_URL=
